<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>The Local Shop – Fresh Finds, Best Prices</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <style>
    :root {
      --cream: #fdf6ee;
      --warm-white: #fffaf4;
      --blush: #f5c4b0;
      --rose: #e8856a;
      --deep-rose: #c0503a;
      --charcoal: #1e1a18;
      --mid: #6b5e57;
      --light-border: #e8ddd5;
      --card-bg: #fff9f5;
      --shadow: 0 8px 32px rgba(100,50,30,0.10);
      --shadow-hover: 0 16px 48px rgba(100,50,30,0.18);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--charcoal);
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 5vw;
      background: rgba(253,246,238,0.85);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--light-border);
      transition: box-shadow .3s;
    }
    nav.scrolled { box-shadow: var(--shadow); }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem; font-weight: 900;
      color: var(--charcoal); letter-spacing: -0.5px;
    }
    .nav-logo span { color: var(--rose); }
    .nav-right { display: flex; align-items: center; gap: 24px; }
    .nav-link {
      font-size: .9rem; font-weight: 500; color: var(--mid);
      text-decoration: none; transition: color .2s;
    }
    .nav-link:hover { color: var(--rose); }
    #cart-btn {
      position: relative; background: var(--charcoal); color: #fff;
      border: none; border-radius: 50px; padding: 10px 20px;
      font-family: 'DM Sans', sans-serif; font-size: .9rem; font-weight: 600;
      cursor: pointer; display: flex; align-items: center; gap: 8px;
      transition: background .2s, transform .15s;
    }
    #cart-btn:hover { background: var(--rose); transform: scale(1.04); }
    #cart-count {
      background: var(--rose); color: #fff;
      border-radius: 50%; width: 20px; height: 20px;
      display: flex; align-items: center; justify-content: center;
      font-size: .72rem; font-weight: 700;
      transition: transform .2s;
    }
    #cart-count.bump { transform: scale(1.4); }

    /* ── HERO ── */
    .hero {
      margin-top: 72px;
      position: relative; width: 100%; height: 92vh; min-height: 520px;
      overflow: hidden; display: flex; align-items: center;
    }
    .hero-img {
      position: absolute; inset: 0;
      width: 100%; height: 100%; object-fit: cover; object-position: center top;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(100deg, rgba(30,26,24,.62) 0%, rgba(30,26,24,.1) 65%, transparent 100%);
    }
    .hero-content {
      position: relative; z-index: 2;
      padding: 0 8vw; max-width: 620px;
      animation: fadeUp .9s ease both;
    }
    .hero-eyebrow {
      font-size: .82rem; font-weight: 600; letter-spacing: 3px;
      color: var(--blush); text-transform: uppercase; margin-bottom: 16px;
    }
    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 6vw, 5rem); line-height: 1.08;
      color: #fff; font-weight: 900; margin-bottom: 20px;
    }
    .hero-title em { color: var(--blush); font-style: italic; }
    .hero-sub {
      font-size: 1.1rem; color: rgba(255,255,255,.82);
      font-weight: 300; margin-bottom: 36px; line-height: 1.6;
    }
    .btn-hero {
      display: inline-block;
      background: var(--rose); color: #fff;
      padding: 16px 40px; border-radius: 50px;
      font-weight: 600; font-size: 1rem; text-decoration: none;
      transition: background .2s, transform .15s, box-shadow .2s;
      box-shadow: 0 4px 20px rgba(232,133,106,.45);
    }
    .btn-hero:hover { background: var(--deep-rose); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(232,133,106,.55); }

    /* ── SECTION LABEL ── */
    .section-label {
      text-align: center; padding: 72px 5vw 8px;
    }
    .section-label h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: var(--charcoal);
    }
    .section-label p {
      color: var(--mid); font-size: 1rem; margin-top: 8px;
    }
    .divider {
      width: 56px; height: 3px; background: var(--rose);
      border-radius: 2px; margin: 14px auto 0;
    }

    /* ── CAROUSEL ── */
    .carousel-wrap {
      padding: 36px 5vw 64px;
      position: relative;
    }
    .carousel {
      display: flex; gap: 24px;
      overflow-x: auto; scroll-snap-type: x mandatory;
      scroll-behavior: smooth; padding-bottom: 16px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin; scrollbar-color: var(--blush) transparent;
    }
    .carousel::-webkit-scrollbar { height: 5px; }
    .carousel::-webkit-scrollbar-thumb { background: var(--blush); border-radius: 3px; }

    .product-card {
      flex: 0 0 260px; background: var(--card-bg);
      border-radius: 20px; overflow: hidden;
      border: 1px solid var(--light-border);
      box-shadow: var(--shadow);
      scroll-snap-align: start;
      transition: transform .3s, box-shadow .3s;
      display: flex; flex-direction: column;
    }
    .product-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); }
    .product-card img {
      width: 100%; height: 220px; object-fit: cover;
      transition: transform .4s;
    }
    .product-card:hover img { transform: scale(1.04); }
    .product-info { padding: 18px; flex: 1; display: flex; flex-direction: column; }
    .product-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem; font-weight: 700; color: var(--charcoal);
      margin-bottom: 6px;
    }
    .product-price {
      font-size: 1.15rem; font-weight: 700; color: var(--rose);
      margin-bottom: 14px;
    }
    .add-to-cart {
      margin-top: auto;
      width: 100%; padding: 11px;
      background: var(--charcoal); color: #fff;
      border: none; border-radius: 12px;
      font-family: 'DM Sans', sans-serif; font-size: .92rem; font-weight: 600;
      cursor: pointer; transition: background .2s, transform .15s;
    }
    .add-to-cart:hover { background: var(--rose); transform: scale(1.02); }
    .add-to-cart.added { background: #4caf50; }

    /* Carousel nav */
    .carousel-nav {
      display: flex; justify-content: center; gap: 12px; margin-top: 4px;
    }
    .carousel-nav button {
      background: var(--charcoal); color: #fff; border: none;
      border-radius: 50%; width: 38px; height: 38px;
      font-size: 1rem; cursor: pointer; transition: background .2s;
    }
    .carousel-nav button:hover { background: var(--rose); }

    /* ── CART DRAWER ── */
    .cart-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(30,26,24,.4); z-index: 200;
      backdrop-filter: blur(4px);
    }
    .cart-overlay.open { display: block; }
    .cart-drawer {
      position: fixed; right: 0; top: 0; bottom: 0; z-index: 201;
      width: min(420px, 95vw); background: var(--warm-white);
      box-shadow: -8px 0 48px rgba(30,26,24,.18);
      display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform .35s cubic-bezier(.4,0,.2,1);
    }
    .cart-drawer.open { transform: translateX(0); }
    .cart-header {
      padding: 24px 24px 16px; border-bottom: 1px solid var(--light-border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .cart-header h3 {
      font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 900;
    }
    .close-cart {
      background: none; border: none; font-size: 1.5rem;
      cursor: pointer; color: var(--mid); transition: color .2s;
    }
    .close-cart:hover { color: var(--rose); }
    .cart-items { flex: 1; overflow-y: auto; padding: 20px 24px; }
    .cart-empty {
      text-align: center; color: var(--mid);
      padding: 60px 0; font-size: 1rem;
    }
    .cart-item {
      display: flex; gap: 14px; align-items: center;
      padding: 14px 0; border-bottom: 1px solid var(--light-border);
    }
    .cart-item img { width: 58px; height: 58px; object-fit: cover; border-radius: 10px; }
    .cart-item-info { flex: 1; }
    .cart-item-name { font-weight: 600; font-size: .92rem; }
    .cart-item-price { color: var(--rose); font-weight: 600; font-size: .9rem; margin-top: 2px; }
    .cart-item-qty {
      display: flex; align-items: center; gap: 8px; margin-top: 6px;
    }
    .qty-btn {
      background: var(--light-border); border: none; border-radius: 6px;
      width: 26px; height: 26px; font-size: .95rem; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; transition: background .15s;
    }
    .qty-btn:hover { background: var(--blush); }
    .qty-num { font-weight: 700; font-size: .95rem; min-width: 18px; text-align: center; }
    .remove-item { color: var(--mid); background: none; border: none; cursor: pointer; font-size: 1rem; transition: color .2s; }
    .remove-item:hover { color: #c0392b; }

    .cart-footer {
      padding: 20px 24px;
      border-top: 1px solid var(--light-border);
    }
    .cart-total {
      display: flex; justify-content: space-between; align-items: center;
      font-size: 1.1rem; font-weight: 700; margin-bottom: 16px;
    }
    .cart-total span:last-child { color: var(--rose); font-size: 1.3rem; }

    /* Customer form */
    .order-form { margin-bottom: 16px; }
    .order-form input {
      width: 100%; padding: 11px 14px; margin-bottom: 10px;
      border: 1.5px solid var(--light-border); border-radius: 10px;
      background: var(--cream); font-family: 'DM Sans', sans-serif;
      font-size: .93rem; color: var(--charcoal);
      transition: border-color .2s;
      outline: none;
    }
    .order-form input:focus { border-color: var(--rose); }
    .send-order-btn {
      width: 100%; padding: 15px;
      background: var(--rose); color: #fff; border: none; border-radius: 14px;
      font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700;
      cursor: pointer; transition: background .2s, transform .15s;
      letter-spacing: .3px;
    }
    .send-order-btn:hover { background: var(--deep-rose); transform: scale(1.01); }
    .send-order-btn:disabled { background: #ccc; cursor: not-allowed; transform: none; }

    .toast {
      position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: var(--charcoal); color: #fff; padding: 12px 28px;
      border-radius: 50px; font-size: .92rem; font-weight: 500;
      z-index: 400; opacity: 0; transition: opacity .3s, transform .3s;
      pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.success { background: #4caf50; }
    .toast.error { background: #e53935; }

    /* ── WHATSAPP ── */
    .wa-btn {
      position: fixed; bottom: 28px; left: 28px; z-index: 300;
      width: 58px; height: 58px; border-radius: 50%;
      background: #25D366;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,.45);
      text-decoration: none; transition: transform .2s, box-shadow .2s;
    }
    .wa-btn:hover { transform: scale(1.1); box-shadow: 0 8px 30px rgba(37,211,102,.55); }
    .wa-btn svg { width: 30px; height: 30px; fill: #fff; }

    /* ── ABOUT / FOOTER STRIP ── */
    .about-strip {
      background: var(--charcoal); color: #fff;
      padding: 56px 8vw; display: flex;
      flex-wrap: wrap; gap: 40px; justify-content: space-between;
      align-items: flex-start;
    }
    .about-col h4 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem; font-weight: 700; margin-bottom: 10px; color: var(--blush);
    }
    .about-col p, .about-col a {
      font-size: .9rem; color: rgba(255,255,255,.7);
      line-height: 1.7; text-decoration: none;
    }
    .about-col a:hover { color: var(--blush); }

    footer {
      background: #111; color: rgba(255,255,255,.4);
      text-align: center; padding: 18px;
      font-size: .82rem;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(40px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .nav-link { display: none; }
      .hero-title { font-size: 2.4rem; }
      .product-card { flex: 0 0 220px; }
      .about-strip { flex-direction: column; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav id="main-nav">
  <div class="nav-logo">the <span>local</span> shop</div>
  <div class="nav-right">
    <a href="#products" class="nav-link">Products</a>
    <a href="#about" class="nav-link">About</a>
    <button id="cart-btn" onclick="openCart()">
      🛒 Cart <span id="cart-count">0</span>
    </button>
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <img src="https://i.ibb.co/vC8rXdXw/beautiful-smiling-young-blonde-woman-pointing-sunglasses-holding-shopping-bags-credit-card-pink-wall.jpg"
       alt="The Local Shop Hero" class="hero-img"/>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-eyebrow">✦ Welcome to</p>
    <h1 class="hero-title">The <em>Local</em><br>Shop</h1>
    <p class="hero-sub">Fresh Finds, Best Prices — curated just for you, delivered with love.</p>
    <a href="#products" class="btn-hero">Shop Now →</a>
  </div>
</section>

<!-- PRODUCTS -->
<section id="products">
  <div class="section-label">
    <h2>Our Products</h2>
    <p>Hand-picked favourites at unbeatable prices</p>
    <div class="divider"></div>
  </div>

  <div class="carousel-wrap">
    <div class="carousel" id="product-carousel"></div>
    <div class="carousel-nav">
      <button onclick="scrollCarousel(-1)" title="Previous">‹</button>
      <button onclick="scrollCarousel(1)" title="Next">›</button>
    </div>
  </div>
</section>

<!-- ABOUT -->
<div class="about-strip" id="about">
  <div class="about-col">
    <h4>The Local Shop</h4>
    <p>Your neighbourhood store for everyday essentials,<br>beauty, and lifestyle finds — fresh every week.</p>
  </div>
  <div class="about-col">
    <h4>Get in Touch</h4>
    <p><a href="mailto:thelocalshop@gmail.com">thelocalshop@gmail.com</a></p>
    <p><a href="https://wa.me/9999999999" target="_blank">WhatsApp Us</a></p>
  </div>
  <div class="about-col">
    <h4>Quick Links</h4>
    <p><a href="#home">Home</a></p>
    <p><a href="#products">Products</a></p>
  </div>
</div>
<footer>© 2025 The Local Shop. All rights reserved.</footer>

<!-- CART OVERLAY + DRAWER -->
<div class="cart-overlay" id="cart-overlay" onclick="closeCart()"></div>
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-header">
    <h3>Your Cart 🛍</h3>
    <button class="close-cart" onclick="closeCart()">✕</button>
  </div>
  <div class="cart-items" id="cart-items"></div>
  <div class="cart-footer">
    <div class="cart-total">
      <span>Total</span>
      <span id="cart-total-price">₹0</span>
    </div>
    <div class="order-form">
      <input type="text" id="customer-name" placeholder="Your Name *" required/>
      <input type="tel" id="customer-phone" placeholder="Phone Number *" required/>
    </div>
    <button class="send-order-btn" id="send-order-btn" onclick="sendOrder()">
      Send Order via Email ✉
    </button>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- WHATSAPP -->
<a href="https://wa.me/9999999999" target="_blank" class="wa-btn" title="Chat on WhatsApp">
  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
    <path d="M16.002 2C8.282 2 2 8.281 2 16c0 2.48.654 4.808 1.793 6.822L2 30l7.395-1.77A13.94 13.94 0 0016.002 30C23.719 30 30 23.72 30 16S23.719 2 16.002 2zm0 25.6a11.547 11.547 0 01-5.88-1.607l-.42-.25-4.387 1.05 1.074-4.263-.275-.44A11.524 11.524 0 014.4 16c0-6.398 5.205-11.6 11.602-11.6S27.6 9.602 27.6 16 22.399 27.6 16.002 27.6zm6.37-8.673c-.35-.175-2.07-1.02-2.39-1.136-.32-.117-.553-.175-.787.174-.234.35-.904 1.136-1.107 1.37-.204.233-.407.263-.757.088-.35-.175-1.477-.544-2.813-1.736-1.04-.927-1.742-2.073-1.946-2.423-.204-.35-.022-.539.153-.713.158-.156.35-.408.525-.612.175-.204.233-.35.35-.583.116-.233.058-.438-.03-.612-.087-.175-.787-1.894-1.078-2.594-.284-.68-.572-.587-.787-.598l-.671-.012c-.233 0-.612.087-.932.438-.32.35-1.224 1.195-1.224 2.914 0 1.72 1.253 3.38 1.428 3.614.175.234 2.466 3.764 5.977 5.278.835.36 1.487.575 1.996.736.838.266 1.602.228 2.206.138.672-.1 2.07-.846 2.362-1.664.291-.817.291-1.518.204-1.664-.087-.146-.32-.233-.67-.408z"/>
  </svg>
</a>

<script>
  // ── EmailJS init ──
  emailjs.init("YOUR_EMAILJS_PUBLIC_KEY"); // ← Replace with your EmailJS public key

  // ── Products data ──
  const products = [
    { id:1, name:"Casual Tote Bag",        price:499,  img:"https://i.ibb.co/8DBxX5D3/download-1.jpg" },
    { id:2, name:"Body Wash & Shower Gel", price:299,  img:"https://i.ibb.co/yFZPCM83/Body-Wash-Shower-Gel-or-Bar-Soap-How-to-Know-Which-Is-Right-for-You.jpg" },
    { id:3, name:"AI Beauty Product",      price:899,  img:"https://i.ibb.co/qMFkfgC4/Visualization-of-AI-products-Content-for-brands-Photo-AI.jpg" },
    { id:4, name:"Stylish Sunglasses",     price:649,  img:"https://i.ibb.co/spBkZFxf/download.jpg" },
    { id:5, name:"Hydrating Glow Serum",   price:1199, img:"https://i.ibb.co/0VGYtx6m/Brings-Multi-Serum-70-Hydrating-Glow-Serum-Glass-Skin-Aesthetic-Skincare.jpg" },
    { id:6, name:"Luxury Beauty Set",      price:1499, img:"https://i.ibb.co/wZxQzPWG/The-Biggest-Beauty-Product-Trend-of-2019-Is-Almost-Good-Enough-to-Eat.jpg" },
  ];

  let cart = [];

  // ── Render products ──
  const carousel = document.getElementById('product-carousel');
  products.forEach(p => {
    const card = document.createElement('div');
    card.className = 'product-card';
    card.innerHTML = `
      <img src="${p.img}" alt="${p.name}" loading="lazy"/>
      <div class="product-info">
        <div class="product-name">${p.name}</div>
        <div class="product-price">₹${p.price}</div>
        <button class="add-to-cart" id="atc-${p.id}" onclick="addToCart(${p.id})">Add to Cart</button>
      </div>`;
    carousel.appendChild(card);
  });

  // ── Cart logic ──
  function addToCart(id) {
    const product = products.find(p => p.id === id);
    const existing = cart.find(i => i.id === id);
    if (existing) { existing.qty++; }
    else { cart.push({ ...product, qty: 1 }); }
    updateCartUI();
    bumpCount();
    const btn = document.getElementById(`atc-${id}`);
    btn.textContent = '✓ Added'; btn.classList.add('added');
    setTimeout(() => { btn.textContent = 'Add to Cart'; btn.classList.remove('added'); }, 1400);
    showToast(`"${product.name}" added to cart!`);
  }

  function removeFromCart(id) {
    cart = cart.filter(i => i.id !== id);
    updateCartUI();
  }

  function changeQty(id, delta) {
    const item = cart.find(i => i.id === id);
    if (!item) return;
    item.qty += delta;
    if (item.qty <= 0) removeFromCart(id);
    else updateCartUI();
  }

  function updateCartUI() {
    const count = cart.reduce((a, i) => a + i.qty, 0);
    document.getElementById('cart-count').textContent = count;
    const total = cart.reduce((a, i) => a + i.price * i.qty, 0);
    document.getElementById('cart-total-price').textContent = `₹${total}`;

    const container = document.getElementById('cart-items');
    if (!cart.length) {
      container.innerHTML = `<div class="cart-empty">🛒<br><br>Your cart is empty.<br>Add some products!</div>`;
      return;
    }
    container.innerHTML = cart.map(i => `
      <div class="cart-item">
        <img src="${i.img}" alt="${i.name}"/>
        <div class="cart-item-info">
          <div class="cart-item-name">${i.name}</div>
          <div class="cart-item-price">₹${i.price} × ${i.qty} = ₹${i.price * i.qty}</div>
          <div class="cart-item-qty">
            <button class="qty-btn" onclick="changeQty(${i.id},-1)">−</button>
            <span class="qty-num">${i.qty}</span>
            <button class="qty-btn" onclick="changeQty(${i.id},1)">+</button>
          </div>
        </div>
        <button class="remove-item" onclick="removeFromCart(${i.id})">🗑</button>
      </div>`).join('');
  }

  function bumpCount() {
    const el = document.getElementById('cart-count');
    el.classList.add('bump');
    setTimeout(() => el.classList.remove('bump'), 300);
  }

  function openCart() {
    document.getElementById('cart-overlay').classList.add('open');
    document.getElementById('cart-drawer').classList.add('open');
    document.body.style.overflow = 'hidden';
    updateCartUI();
  }

  function closeCart() {
    document.getElementById('cart-overlay').classList.remove('open');
    document.getElementById('cart-drawer').classList.remove('open');
    document.body.style.overflow = '';
  }

  // ── Send order via EmailJS ──
  function sendOrder() {
    const name = document.getElementById('customer-name').value.trim();
    const phone = document.getElementById('customer-phone').value.trim();
    if (!name || !phone) { showToast('Please enter your name and phone number.', 'error'); return; }
    if (!cart.length) { showToast('Your cart is empty!', 'error'); return; }

    const itemsText = cart.map(i => `• ${i.name} (Qty: ${i.qty}) — ₹${i.price * i.qty}`).join('\n');
    const total = cart.reduce((a, i) => a + i.price * i.qty, 0);

    const btn = document.getElementById('send-order-btn');
    btn.disabled = true; btn.textContent = 'Sending…';

    // EmailJS send
    emailjs.send("YOUR_SERVICE_ID", "YOUR_TEMPLATE_ID", {
      customer_name: name,
      customer_phone: phone,
      order_items: itemsText,
      order_total: `₹${total}`,
      to_email: "thelocalshop@gmail.com"
    }).then(() => {
      showToast('Order sent successfully! 🎉 We\'ll contact you soon.', 'success');
      cart = [];
      updateCartUI();
      document.getElementById('customer-name').value = '';
      document.getElementById('customer-phone').value = '';
      btn.disabled = false; btn.textContent = 'Send Order via Email ✉';
      setTimeout(closeCart, 2000);
    }).catch(err => {
      console.error(err);
      // Fallback: mailto
      const subject = encodeURIComponent(`New Order from ${name}`);
      const body = encodeURIComponent(`Customer: ${name}\nPhone: ${phone}\n\nOrder:\n${itemsText}\n\nTotal: ₹${total}`);
      window.open(`mailto:thelocalshop@gmail.com?subject=${subject}&body=${body}`);
      showToast('Opening your mail app as fallback.', 'success');
      btn.disabled = false; btn.textContent = 'Send Order via Email ✉';
    });
  }

  // ── Carousel nav ──
  function scrollCarousel(dir) {
    carousel.scrollBy({ left: dir * 280, behavior: 'smooth' });
  }

  // ── Auto-scroll ──
  let autoTimer = setInterval(() => {
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;
    if (carousel.scrollLeft >= maxScroll - 10) carousel.scrollLeft = 0;
    else carousel.scrollBy({ left: 280, behavior: 'smooth' });
  }, 3200);
  carousel.addEventListener('mouseenter', () => clearInterval(autoTimer));
  carousel.addEventListener('mouseleave', () => {
    autoTimer = setInterval(() => {
      const maxScroll = carousel.scrollWidth - carousel.clientWidth;
      if (carousel.scrollLeft >= maxScroll - 10) carousel.scrollLeft = 0;
      else carousel.scrollBy({ left: 280, behavior: 'smooth' });
    }, 3200);
  });

  // ── Nav scroll effect ──
  window.addEventListener('scroll', () => {
    document.getElementById('main-nav').classList.toggle('scrolled', window.scrollY > 20);
  });

  // ── Toast ──
  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = `toast ${type} show`;
    setTimeout(() => t.classList.remove('show'), 3000);
  }
</script>
</body>
</html>
